# Environment Variables - Copy this file to .env and fill in actual values
# DO NOT commit .env file (it contains secrets!)

# ============================================================================
# Server Configuration
# ============================================================================
DEBUG=False
ENVIRONMENT=development
SERVICE_NAME=video-analytics-api

# ============================================================================
# Security & Authentication
# ============================================================================
# REQUIRED: Generate a strong random secret key
# Python: import secrets; print(secrets.token_urlsafe(32))
SECRET_KEY=your_long_random_secret_key_here_minimum_32_chars

# JWT Token Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# Google Gemini AI Configuration
# ============================================================================
# REQUIRED: Get your API key from https://ai.google.dev
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.0
GEMINI_TIMEOUT_SECONDS=300

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://example.com

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum file size in bytes (200MB = 200 * 1024 * 1024)
MAX_FILE_SIZE_BYTES=209715200

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
